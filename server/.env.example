# 服务端配置示例
# 复制这个文件为 .env 或 .env.docker，然后填入真实值

# 服务配置
PORT=3000
NODE_ENV=development

# 数据库连接
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai-lowcode-platform

# Redis 连接（可选）
REDIS_URL=redis://localhost:6379

# JWT 密钥（请修改为强密码）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# JWT 访问令牌过期时间（例如：15m、1h、7d）
JWT_ACCESS_TOKEN_EXPIRES_IN=1h
# JWT 刷新令牌过期时间（例如：7d、30d）
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# 允许的跨域源（多个地址用逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key-here

# 豆包 (Doubao) 配置
DOUBAO_CHAT_API_KEY=your-doubao-api-key-here
DOUBAO_DEFAULT_CHAT_MODEL=doubao-seed-2-0-pro-260215
DOUBAO_CHAT_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_EMBEDDING_API_KEY=your-doubao-api-key-here
DOUBAO_DEFAULT_EMBEDDING_MODEL=doubao-embedding-vision-251215
DOUBAO_EMBEDDING_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings
DOUBAO_EMBEDDING_DIMENSION=1024

# 通义千问 (Qwen/DashScope) 配置
DASHSCOPE_CHAT_API_KEY=your-dashscope-api-key-here
DASHSCOPE_EMBEDDING_API_KEY=your-dashscope-api-key-here
QWEN_DEFAULT_CHAT_MODEL=qwen-max
QWEN_CHAT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_DEFAULT_EMBEDDING_MODEL=text-embedding-v3
QWEN_EMBEDDING_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding

# Rerank 配置
RERANK_DEFAULT_MODEL=qwen3-rerank

